# ==========================================
# SixSense Doc-Converter Project .gitignore
# ==========================================

# --- 1. 파이썬 빌드 및 가상환경 ---
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.cache
.pytest_cache/
.coverage
htmlcov/

# --- 2. 로그 및 임시 파일 (강력 차단 ) ---
*.log
logs/
log/
nohup.out
*.out
*.err
temp_storage/    # 서비스 운영 중 생성되는 임시 파일 폴더
storage/
data/

# --- 3. 보안 및 민감 정보 (절대 업로드 금지) ---
.env
.env.*
*.pem
*.key
*.pub
secrets.yaml
config.json

# --- 4. 인프라 및 도커 관련 ---
# 테라폼 상태 파일 (로컬 협업 시 주의)
*.tfstate
*.tfstate.backup
.terraform/

# 도커 관련
.dockerignore

# --- 5. OS 및 IDE 설정 ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# --- 6. 정적 자원 및 문서 (정밀 제어 ) ---
# 모든 문서/이미지 파일을 기본적으로 차단하여 실수 방지
*.pdf
*.hwp
*.docx
*.doc
*.png
*.jpg
*.jpeg
*.gif

# [핵심] 서비스 운영에 필수적인 정적 파일은 예외적으로 허용 
!static/
!static/*.png
!static/*.jpg
!static/*.jpeg
!static/*.svg
!static/*.ico
!.gitkeep

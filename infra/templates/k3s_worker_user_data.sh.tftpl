#!/bin/bash
# K3s worker node가 부팅될 때 실행된다.
# control-plane에 자동 조인하고 worker 전용 label을 부여한다.

set -euo pipefail

export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y curl tar

curl -sfL https://get.k3s.io | \
  K3S_URL="https://${server_private_ip}:6443" \
  K3S_TOKEN="${k3s_token}" \
  INSTALL_K3S_EXEC="agent --node-label node-role.k3s-project.io/worker=true --node-label workload=general" \
  sh -

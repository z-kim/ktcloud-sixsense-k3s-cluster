# dev 환경 예시 값이다.
# 실제 적용 전에는 admin_cidrs, key_name, owner 등을 현재 계정/접속 환경에 맞게 바꿔야 한다.

aws_region = "ap-northeast-2"

project_name = "k3s-security"
environment  = "dev"
owner        = "team-name"

# bastion SSH 허용 대역.
# 현재 접속 중인 공인 IP/32로 바꾸어야 한다.
# 예: ["1.2.3.4/32"] 또는 ["1.2.3.4/32", "5.6.7.0/24"]
admin_cidrs = ["YOUR_PUBLIC_IP/32"]
# AWS에 설정한 EC2 keypair name을 입력한다.
key_name    = "your-ec2-keypair-name"

nat_mode                  = "instance"
preferred_primary_az      = "ap-northeast-2a"
spread_workers_across_azs = false

bastion_instance_type    = "t3.micro"
nat_instance_type        = "t3.micro"
k3s_server_instance_type = "t3.small"
k3s_worker_instance_type = "t3.small"

worker_min_size     = 1
worker_desired_size = 1
worker_max_size     = 2

enable_mysql_rds = true
mysql_multi_az   = false
mysql_db_name    = "app"
mysql_username   = "appuser"
mysql_password   = "change-me-please"

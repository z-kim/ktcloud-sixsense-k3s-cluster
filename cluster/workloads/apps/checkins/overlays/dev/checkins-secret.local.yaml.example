# 로컬 전용 Checkins DB Secret 예시 파일이다.
# 실제 적용할 때는 이 파일을 복사해 checkins-secret.local.yaml 로 만들고,
# <RDS_ENDPOINT> 자리를 실제 Terraform output 값으로 바꾼다.

apiVersion: v1
kind: Secret
metadata:
  name: checkins-secret
  namespace: apps
type: Opaque
stringData:
  database-url: mysql://<DB_USERNAME>:<DB_PASSWORD>@<RDS_ENDPOINT>:3306/checkinsdb

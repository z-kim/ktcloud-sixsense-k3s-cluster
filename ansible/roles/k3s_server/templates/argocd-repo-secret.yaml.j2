apiVersion: v1
kind: Secret
metadata:
  name: argocd-repo-private
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  url: {{ argocd_repo_url }}
  sshPrivateKey: |
{% for line in argocd_repo_ssh_private_key.splitlines() %}
    {{ line }}
{% endfor %}
